# 人力资源智能体系统 - 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ============================================
# 数据库配置
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=workspace_management

# ============================================
# 文心一言API配置（可选）
# 用于增强自然语言搜索功能
# ============================================
# V3版本Key (格式: bce-v3/ALTAK-xxx/xxx)
WENXIN_V3_KEY=bce-v3/ALTAK-your-key-here

# 模型选择: ernie-bot, ernie-bot-4, ernie-speed, ernie-lite
WENXIN_MODEL=ernie-bot

# ============================================
# 服务端配置
# ============================================
SERVER_PORT=8082
NODE_ENV=development

# ============================================
# 前端配置
# ============================================
FRONTEND_PORT=5173
API_BASE_URL=http://localhost:8082

# ============================================
# JWT配置（生产环境必须修改）
# ============================================
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=24h

# ============================================
# 邮件配置（可选，用于简历推送）
# ============================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
